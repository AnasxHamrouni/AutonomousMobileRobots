<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="base_length" value="0.6" />
    <xacro:property name="base_width" value="0.4" />
    <xacro:property name="base_height" value="0.15" />
    <xacro:property name="wheel_radius" value="0.1" />
    <xacro:property name="wheel_length" value="0.05" />
    <xacro:property name="wheelbase" value="0.5" />
    <xacro:property name="track_width" value="0.4" />
    <xacro:property name="max_steer_angle" value="0.6" />
    <xacro:property name="wheel_separation" value="${track_width + wheel_length}" />
    <xacro:property name="max_wheel_angular_velocity" value="20.0" />

    <!-- Base footprint (ground projection) -->
    <link name="base_footprint" />

    <!-- Chassis -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
            <material name="blue" />
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width - 0.15} ${base_height}" />
            </geometry>
            <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
        </collision>
        <xacro:box_inertia m="5.0" l="${2*base_length}" w="${2*base_width}" h="${2*base_height}"
                           xyz="0 0 ${base_height / 2.0}" rpy="0 0 0" />
    </link>

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link" />
        <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
    </joint>

    <!-- ==================== REAR WHEELS (driven) ==================== -->

    <xacro:macro name="rear_wheel" params="prefix y_offset">
        <link name="rear_${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="grey" />
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${2*wheel_radius}" h="${2*wheel_length}"
                                    xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
        </link>

        <joint name="rear_${prefix}_wheel_joint" type="continuous">
            <parent link="base_link" />
            <child link="rear_${prefix}_wheel_link" />
            <origin xyz="${-wheelbase / 2.0} ${y_offset} 0" rpy="0 0 0" />
            <axis xyz="0 1 0" />
            <dynamics damping="0.1" friction="0.1" />
        </joint>
    </xacro:macro>

    <xacro:rear_wheel prefix="left" y_offset="${wheel_separation / 2.0}" />
    <xacro:rear_wheel prefix="right" y_offset="${-wheel_separation / 2.0}" />

    <!-- ==================== FRONT WHEELS (steered) ==================== -->

    <xacro:macro name="front_steered_wheel" params="prefix y_offset">
        <!-- Steering link -->
        <link name="front_${prefix}_steering_link">
            <visual>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <geometry>
                    <cylinder length="0.001" radius="0.01" />
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <geometry>
                    <cylinder length="0.001" radius="0.01" />
                </geometry>
            </collision>
            <inertial>
                <mass value="0.01" />
                <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0" />
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
            </inertial>
        </link>

        <!-- Steering joint -->
        <joint name="front_${prefix}_steering_joint" type="revolute">
            <parent link="base_link" />
            <child link="front_${prefix}_steering_link" />
            <origin xyz="${wheelbase / 2.0} ${y_offset} 0" rpy="0 0 0" />
            <axis xyz="0 0 1" />
            <limit effort="1.0" lower="${-max_steer_angle}" upper="${max_steer_angle}" velocity="1.57" />
            <dynamics damping="0.1" friction="0.1" />
        </joint>

        <!-- Wheel link -->
        <link name="front_${prefix}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <material name="grey" />
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_length}" />
                </geometry>
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${2*wheel_radius}" h="${2*wheel_length}"
                                    xyz="0 0 0" rpy="${pi / 2.0} 0 0" />
        </link>

        <!-- Wheel rotation joint -->
        <joint name="front_${prefix}_wheel_joint" type="continuous">
            <parent link="front_${prefix}_steering_link" />
            <child link="front_${prefix}_wheel_link" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <axis xyz="0 1 0" />
            <dynamics damping="0.1" friction="0.1" />
        </joint>
    </xacro:macro>

    <xacro:front_steered_wheel prefix="left" y_offset="${wheel_separation / 2.0}" />
    <xacro:front_steered_wheel prefix="right" y_offset="${-wheel_separation / 2.0}" />

    <!-- ==================== LiDAR ==================== -->
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link" />
        <child link="lidar_link" />
        <origin xyz="0.2 0 0.2" rpy="0 0 0" />
    </joint>

    <link name="lidar_link">
        <visual>
            <geometry>
                <cylinder radius="0.04" length="0.04" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="black" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.04" length="0.04" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1" />
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001"
                     ixy="0" ixz="0" iyz="0" />
        </inertial>
    </link>

    <!-- ==================== ros2_control ==================== -->
    <ros2_control name="ackermann_control" type="system">
        <hardware>
            <plugin>gazebo_ros2_control/GazeboSystem</plugin>
        </hardware>

        <joint name="front_left_steering_joint">
            <command_interface name="position">
                <param name="min">${-max_steer_angle}</param>
                <param name="max">${max_steer_angle}</param>
            </command_interface>
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="front_right_steering_joint">
            <command_interface name="position">
                <param name="min">${-max_steer_angle}</param>
                <param name="max">${max_steer_angle}</param>
            </command_interface>
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="rear_left_wheel_joint">
            <command_interface name="velocity">
                <param name="min">${-max_wheel_angular_velocity}</param>
                <param name="max">${max_wheel_angular_velocity}</param>
            </command_interface>
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="rear_right_wheel_joint">
            <command_interface name="velocity">
                <param name="min">${-max_wheel_angular_velocity}</param>
                <param name="max">${max_wheel_angular_velocity}</param>
            </command_interface>
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="front_left_wheel_joint">
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>

        <joint name="front_right_wheel_joint">
            <state_interface name="position" />
            <state_interface name="velocity" />
        </joint>
    </ros2_control>

</robot>
